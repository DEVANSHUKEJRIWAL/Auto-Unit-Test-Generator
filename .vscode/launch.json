{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Sentinel Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--disable-extensions"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "env": {
                "GEMINI_API_KEY": "YOUR_API_KEY_HERE"
            }
        }
    ]
}