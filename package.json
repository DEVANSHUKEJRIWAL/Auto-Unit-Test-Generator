{
  "name": "autotest-sentinel",
  "displayName": "AutoTest Sentinel",
  "description": "Autonomous AI unit test generation agent.",
  "version": "0.0.1",
  "publisher": "devanshu-kejriwal",
  "engines": {
    "vscode": "^1.85.0"
  },
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sentinel-sidebar",
          "title": "Sentinel AI",
          "icon": "media/shield.svg"
        }
      ]
    },
    "views": {
      "sentinel-sidebar": [
        {
          "id": "sentinel-agent-status",
          "name": "Command Center",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "sentinel.promptRequirements",
        "title": "✨ Sentinel: Generate Unit Test"
      }
    ]
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@langchain/google-genai": "^2.1.26",
    "vscode-languageclient": "^9.0.1"
  },
  "scripts": {
    "postinstall": "cd sentinel-ls && npm install",
    "compile": "npm run check-types && node esbuild.js",
    "package": "vsce package",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.x",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.0.0"
  }
}